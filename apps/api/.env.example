# API runtime
PORT=3001
IMAAN_PREFER_PROCESS_ENV=1
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional local-only dev bearer-token bypass. Keep real values out of git and shared deployments.
IMAAN_DEV_AUTH_BYPASS=0
IMAAN_DEV_AUTH_BYPASS_TOKEN=
IMAAN_DEV_AUTH_BYPASS_USER_ID=
OPENROUTER_API_KEY=
# Required for /v1/interventions and must support json_schema structured outputs.
OPENROUTER_MODEL=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ALLOWED_ORIGIN=
EMBEDDING_PROVIDER=openai_compatible
# Leave blank to reuse OPENROUTER_API_KEY when EMBEDDING_PROVIDER=openai_compatible.
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768
EMBEDDING_BASE_URL=

# Azure deploy script
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=imaan-api-rg
AZURE_CONTAINERAPPS_ENV=imaan-api-env
AZURE_CONTAINERAPP_NAME=imaan-api
# Azure Container Registry names are globally unique.
AZURE_ACR_NAME=
AZURE_IMAGE_REPOSITORY=imaan-api
AZURE_IMAGE_TAG=
AZURE_CPU=0.5
AZURE_MEMORY=1.0Gi
AZURE_MIN_REPLICAS=0
AZURE_MAX_REPLICAS=2
AZURE_WORKLOAD_PROFILE=Consumption
